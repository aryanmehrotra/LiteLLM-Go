meta {
  name: Create Fine-Tuning Job
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/fine_tuning/jobs
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{gatewayKey}}
  Content-Type: application/json
}

body:json {
  {
    "model": "openai/gpt-4o-mini",
    "training_file": "file-abc123",
    "hyperparameters": {
      "n_epochs": "auto"
    }
  }
}
