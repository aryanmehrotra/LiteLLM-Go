meta {
  name: Add Message to Thread
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/v1/threads/thread_abc123/messages
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{gatewayKey}}
  Content-Type: application/json
}

body:json {
