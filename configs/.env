# ============================================
# LLM Gateway Configuration
# ============================================

# ============================================
# REQUIRED CORE
# ============================================
APP_NAME=llm-gateway
HTTP_PORT=9000
GATEWAY_API_KEYS=sk-gateway-key-1,sk-gateway-key-2
DEFAULT_PROVIDER=ollama

# ============================================
# PROVIDERS (uncomment and set the ones you use)
# ============================================
# Only providers with valid API keys are registered.
# Unconfigured providers won't appear in the model list.
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=AI...
OLLAMA_BASE_URL=http://localhost:11434

# Per-provider timeouts in milliseconds (optional, 0 = no timeout)
# OPENAI_TIMEOUT_MS=30000
# ANTHROPIC_TIMEOUT_MS=60000
# GROQ_TIMEOUT_MS=15000
# DEEPSEEK_TIMEOUT_MS=30000
# GEMINI_TIMEOUT_MS=30000
# OLLAMA_TIMEOUT_MS=120000

# ============================================
# INFRASTRUCTURE
# ============================================
# Redis (required for response caching and rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=300

# PostgreSQL (required for budgets, virtual keys, multi-tenancy)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=llmgw
DB_DIALECT=postgres

# ============================================
# VIRTUAL KEYS & ADMIN (required for admin UI)
# ============================================
GATEWAY_MASTER_KEY=sk-master-admin-2026

# ============================================
# ROUTING (advanced, all optional)
# ============================================
# Retry & cooldown
RETRY_MAX=3
RETRY_BACKOFF_BASE_MS=500
COOLDOWN_THRESHOLD=5
COOLDOWN_PERIOD_SECONDS=60

# Strategy: simple | round-robin | weighted | least-busy | latency | usage
ROUTING_STRATEGY=simple
LATENCY_EMA_ALPHA=0.2
USAGE_RESET_PERIOD_SECONDS=60

# Circuit breaker
CB_THRESHOLD=5
CB_INTERVAL_SECONDS=30

# Fallback chain (optional, comma-separated provider names)
# FALLBACK_CHAIN=openai,anthropic,ollama

# Per-key fallback overrides
# Format: key:provider1,provider2;key2:provider3,provider4
# GATEWAY_KEY_CONFIG=sk-key-1:openai,anthropic;sk-key-2:anthropic,ollama

# Request queuing (optional)
REQUEST_QUEUE_ENABLED=false
REQUEST_QUEUE_SIZE=100

# ============================================
# GUARDRAILS (optional, content filtering)
# ============================================
# GUARDRAIL_ENABLED=true
# GUARDRAIL_BLOCKED_KEYWORDS=hack,exploit,jailbreak
# GUARDRAIL_PII_ACTION=none   # none | block | redact | log
# GUARDRAIL_MAX_INPUT_TOKENS=0  # 0 = unlimited
# GUARDRAIL_MAX_OUTPUT_TOKENS=0 # 0 = unlimited

# ============================================
# BATCH PROCESSING
# ============================================
BATCH_WORKERS=5
BATCH_TASK_TIMEOUT_SECONDS=120

# ============================================
# COST & PRICING (optional)
# ============================================
# Custom pricing per 1K tokens.
# Format: model:input_cost:output_cost,model2:input_cost:output_cost
# CUSTOM_PRICING=my-model:0.001:0.002,other-model:0.01:0.03

# ============================================
# OBSERVABILITY (GoFr built-in)
# ============================================
METRICS_PORT=2123
TRACE_EXPORTER=gofr
LOG_LEVEL=INFO

# ============================================
# WEB SEARCH (optional, gateway-level search augmentation)
# ============================================
# Enable web search augmentation for any model (including Ollama)
WEBSEARCH_ENABLED=true
WEBSEARCH_PROVIDER=searxng
WEBSEARCH_BASE_URL=http://localhost:8080
# WEBSEARCH_API_KEY=                  # Tavily API key (if using tavily)
WEBSEARCH_MAX_RESULTS=5
WEBSEARCH_CACHE_TTL=300
# WEBSEARCH_QUERY_MODEL=              # Model for query formulation (empty = use request's model)
